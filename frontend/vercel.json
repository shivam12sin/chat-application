{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "https://aether-backend-aqse.onrender.com/api",
      "VITE_SOCKET_URL": "https://aether-backend-aqse.onrender.com"
    }
  }
}
